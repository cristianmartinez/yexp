{
  "name": "yexp",
  "version": "0.0.1",
  "description": "Fast, portable JSON expression language with bytecode compilation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "bun run build && bun test",
    "test": "bun test",
    "lint": "biome check src/ tests/",
    "check": "tsc --noEmit --project tsconfig.build.json"
  },
  "keywords": [
    "yexp",
    "expression",
    "json",
    "query",
    "bytecode",
    "compiler",
    "ast",
    "safe",
    "portable"
  ],
  "author": "Cristian Martinez <dev.cmartinez@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cristianmartinez/yexp.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/cristianmartinez/yexp#readme",
  "bugs": {
    "url": "https://github.com/cristianmartinez/yexp/issues"
  },
  "devDependencies": {
    "bun-types": "^1.3.8"
  }
}
