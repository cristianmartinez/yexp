{
  "name": "@cristianmartinez/yexp-cli",
  "version": "0.0.1",
  "type": "module",
  "description": "CLI for Yexp expression language",
  "bin": {
    "yexp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --packages external",
    "build:bin": "bun build src/index.ts --compile --outfile dist/yexp",
    "prepublishOnly": "bun run build && bun test",
    "dev": "bun run src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@cristianmartinez/yexp": "^0.0.1",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.8",
    "@types/node": "^20.10.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "yexp",
    "json",
    "query",
    "expression",
    "cli",
    "jq"
  ],
  "author": "Cristian Martinez <dev.cmartinez@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cristianmartinez/yexp.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/cristianmartinez/yexp#readme",
  "bugs": {
    "url": "https://github.com/cristianmartinez/yexp/issues"
  }
}
