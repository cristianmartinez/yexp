{
  "name": "@cristianmartinez/yexp-cli",
  "version": "0.0.1",
  "type": "module",
  "description": "Query and transform JSON with familiar expressions",
  "bin": {
    "yexp": "dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --packages external",
    "build:bin": "bun build src/index.ts --compile --outfile dist/yexp",
    "prepublishOnly": "bun run test",
    "dev": "bun run src/index.ts",
    "test": "bun run build && bun test --bail",
    "check": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src/ tests/ --diagnostic-level=error"
  },
  "dependencies": {
    "@cristianmartinez/yexp": "^0.0.1",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.8",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "keywords": ["yexp", "json", "query", "expression", "cli", "jq"],
  "author": "Cristian Martinez <dev.cmartinez@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cristianmartinez/yexp.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/cristianmartinez/yexp#readme",
  "bugs": {
    "url": "https://github.com/cristianmartinez/yexp/issues"
  }
}
