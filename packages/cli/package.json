{
  "name": "@jext/cli",
  "version": "0.0.1",
  "type": "module",
  "description": "CLI for Jext expression language",
  "bin": {
    "jext": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "build:bin": "bun build src/index.ts --compile --outfile dist/jext",
    "dev": "bun run src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@jext/core": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.8",
    "@types/node": "^20.10.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["jext", "json", "query", "expression", "cli"]
}
