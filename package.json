{
  "name": "yexp",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "check": "turbo check",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "playground": "turbo dev --filter=@yexp/playground",
    "playground:portless": "portless yexp bun run --cwd packages/playground dev",
    "playground:build": "turbo build --filter=@yexp/playground",
    "release:check": "node scripts/verify-release.mjs",
    "release:pack": "node scripts/verify-packages.mjs",
    "ci": "bun run format:check && bun run lint && bun run check && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "portless": "^0.15.4",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@xmldom/xmldom": "0.9.10",
    "dompurify": "3.4.12",
    "lodash-es": "4.18.1",
    "mermaid": "11.16.0",
    "minimatch": "10.2.5",
    "picomatch": "2.3.2",
    "postcss": "8.5.19",
    "uuid": "14.0.1",
    "yaml": "2.9.0"
  }
}
