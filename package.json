{
  "name": "yexp",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": ["packages/*", "evals"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "check": "turbo check",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "playground": "turbo dev --filter=@yexp/playground",
    "playground:build": "turbo build --filter=@yexp/playground",
    "release:check": "node scripts/verify-release.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@tailwindcss/typography": "^0.5.19",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1"
  }
}
